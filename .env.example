# ============================================================
# AppleTree Family — Variables de Entorno
# Copia este archivo a apps/web/.env.local y llena los valores
# NUNCA subas .env.local a GitHub
# ============================================================

# --- SUPABASE ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY   # Solo en backend, nunca en frontend

# --- CLOUDINARY (Fotos de perfil / nodos manzana) ---
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=YOUR_CLOUD_NAME
CLOUDINARY_API_KEY=YOUR_API_KEY
CLOUDINARY_API_SECRET=YOUR_API_SECRET

# --- BACKBLAZE B2 (Álbumes de fotos) ---
B2_APPLICATION_KEY_ID=YOUR_B2_KEY_ID
B2_APPLICATION_KEY=YOUR_B2_APP_KEY
B2_BUCKET_NAME=appletree-albums
B2_BUCKET_ID=YOUR_BUCKET_ID
B2_ENDPOINT=https://s3.YOUR_REGION.backblazeb2.com

# --- CLOUDFLARE CDN (URLs públicas de álbumes) ---
NEXT_PUBLIC_CDN_DOMAIN=https://cdn.yourdomain.com

# --- RAILWAY BACKEND API ---
NEXT_PUBLIC_API_URL=https://appletree-api.railway.app
API_SECRET_KEY=YOUR_SECRET_KEY_FOR_BACKEND

# --- APP CONFIG ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=AppleTree Family
