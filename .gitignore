# ============================================================
# AppleTree Family — .gitignore
# ============================================================

# --- Environment Variables (NEVER commit these) ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production
*.env

# --- Next.js ---
apps/web/.next/
apps/web/out/
apps/web/build/
apps/web/.vercel

# --- Node / npm ---
node_modules/
apps/web/node_modules/
backend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Python (backend FastAPI alternative) ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
backend/venv/
backend/.venv/
*.egg-info/
dist/
*.so

# --- OS Files ---
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

# --- IDEs ---
.vscode/
.idea/
*.swp
*.swo

# --- Logs ---
logs/
*.log

# --- Supabase local dev ---
supabase/.branches/
supabase/.temp/

# --- Cloudinary / B2 credentials ---
cloudinary.json
b2_credentials.json
